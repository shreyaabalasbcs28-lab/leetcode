class Solution:
    def isValid(self, s: str) -> bool:
        l = []
        for i in s:
            if i == "(" or i == "[" or i == "{":
                l.append(i)
            else:
                if not l:
                    return False
                last = l.pop()
                if i == ")" and last != "(":
                    return False
                if i == "]" and last != "[":
                    return False
                if i == "}" and last != "{":
                    return False
        return len(l) == 0
