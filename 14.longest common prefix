class Solution:
    def longestCommonPrefix(self, strs: List[str]):
        if not strs:
            return ""
        out = ""
        count = 0
        while 1:
            if count == len(strs[0]):
                break
            test = strs[0][count]
            for s in strs[1:]:
                if count == len(s) or s[count] != test:
                    return out
            out += test
            count += 1
        return out
