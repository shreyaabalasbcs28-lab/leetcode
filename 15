class Solution:
    def threeSum(self, nums: list[int]) -> list[list[int]]:
        nums.sort()  # Step 1: Sort the list to use two pointers
        result = []
        
        for i in range(len(nums) - 2):
            # Step 2: Skip the same number to avoid duplicate triplets
            if i > 0 and nums[i] == nums[i - 1]:
                continue
                
            # Step 3: Two-pointer setup
            left, right = i + 1, len(nums) - 1
            
            while left < right:
                total = nums[i] + nums[left] + nums[right]
                
                if total < 0:
                    left += 1  # Sum too small, move left pointer right
                elif total > 0:
                    right -= 1 # Sum too large, move right pointer left
                else:
                    # Found a triplet that sums to 0
                    result.append([nums[i], nums[left], nums[right]])
                    
                    # Step 4: Skip duplicates for the 'left' pointer
                    while left < right and nums[left] == nums[left + 1]:
                        left += 1
                    # Step 5: Skip duplicates for the 'right' pointer
                    while left < right and nums[right] == nums[right - 1]:
                        right -= 1
                        
                    # Move both pointers after finding a valid triplet
                    left += 1
                    right -= 1
                    
        return result
